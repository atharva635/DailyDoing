class Solution {
    public int pivotIndex(int[] nums) {
        int n = nums.length;
        int sum = 0;
        for (int i= 0;i<n;i++){
            sum = sum + nums[i];
        }
        int leftsum = 0;
        for(int i = 0;i<n;i++){
            int rightsum = sum - leftsum - nums[i];
            if(rightsum==leftsum){
                return i;
            }
            else{
                leftsum = leftsum + nums[i];
            }
        }
        return -1;
    }
}
