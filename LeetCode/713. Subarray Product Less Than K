class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        if(k<=1){
            return 0;
        }
        int n = nums.length;
        int pro = 1;
        int left = 0;
        int count = 0;
        for (int i=0;i<n;i++){
            pro = pro * nums[i];
            while(pro>=k){
                pro = pro / nums[left];
                left++;
            }
            count = count + (i-left+1);
        }
        return count;
        
    }
}
