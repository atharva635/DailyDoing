class NumArray {
    int[] add;

    public NumArray(int[] nums) {
        int n = nums.length;
        add = new int[n];
        add[0] = nums[0];
        for(int i=1;i<nums.length;i++){
            add[i] = add[i-1] + nums[i];
        }   
    }
    
    public int sumRange(int left, int right) {
        if(left == 0){
            return add[right];
        }
        return add[right]-add[left-1];
        
    }
}

