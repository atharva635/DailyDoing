class Solution {
    public int arrangeCoins(int n) {
        long left = 1;
        long right = n;
        while(left<=right){
            long mid = left + (right - left)/2;
            long sum = mid*(mid+1)/2;
            if(n == sum){
                return (int)mid;
            }
            else if(n>sum){
                left = mid + 1;
            }
            else{
                right = mid - 1;
            }
        }
        return (int)right;
    }
}
